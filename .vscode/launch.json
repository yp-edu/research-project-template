{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Tests",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "purpose": ["debug-test"],
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "hidden": true
            }
        },
        {
            "name": "Debug File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "purpose": ["debug-in-terminal"],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Run Experiment",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.run_experiment",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "demo=first"
            ]
        }
    ]
}
