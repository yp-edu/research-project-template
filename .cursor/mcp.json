{
    "mcpServers": {
        "arxiv-mcp-server": {
            "command": "uv",
            "args": [
                "tool",
                "run",
                "arxiv-mcp-server",
                "--storage-path",
                "${workspaceFolder}/results/arxiv-mcp-server"
            ]
        },
        "exa": {
            "url": "https://mcp.exa.ai/mcp?exaApiKey=${env:EXA_API_KEY}"
        }
    }
}
